#!/bin/sh
set -eu

if [ "${SKIP_PRECOMMIT:-}" = "1" ]; then
  echo "Skipping pre-commit checks because SKIP_PRECOMMIT=1"
  exit 0
fi

STAGED_FILES=$(git diff --cached --name-only)

echo "Running checks..."
bun run check

for file in $STAGED_FILES; do
  if [ -f "$file" ]; then
    git add "$file"
  fi
done

echo "Pre-commit checks passed."
